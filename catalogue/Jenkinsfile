pipeline {
    agent { label 'agent_01' }

    options {
        skipDefaultCheckout(false)
    }

    environment {
        APP_DIR       = 'catalogue'
        NEXUS_URL     = 'http://ec2-44-204-27-33.compute-1.amazonaws.com:8081'
        NEXUS_REPO    = 'catalogue'
        GROUP_ID      = 'com.roboshop'
        PACKAGING     = 'tar.gz'
        NEXUS_CRED_ID = 'nexus-creds'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Info') {
            steps {
                sh 'hostname'
                sh 'whoami'
                sh 'pwd'
                sh 'ls -la'
            }
        }

        stage('Read Application Metadata') {
            steps {
                dir("${APP_DIR}") {
                    script {
                        env.APP_NAME    = sh(script: "node -p \"require('./package.json').name\"", returnStdout: true).trim()
                        env.APP_VERSION = sh(script: "node -p \"require('./package.json').version\"", returnStdout: true).trim()
                        env.GROUP_PATH  = env.GROUP_ID.replace('.', '/')
                        env.FILE_NAME   = "${env.APP_NAME}-${env.APP_VERSION}.${env.PACKAGING}"
                        env.NEXUS_PATH  = "${env.GROUP_PATH}/${env.APP_NAME}/${env.APP_VERSION}/${env.FILE_NAME}"

                        echo "APP_NAME    = ${env.APP_NAME}"
                        echo "APP_VERSION = ${env.APP_VERSION}"
                        echo "FILE_NAME   = ${env.FILE_NAME}"
                        echo "NEXUS_PATH  = ${env.NEXUS_PATH}"
                    }
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Package Artifact') {
            steps {
                sh '''
                    rm -f "${FILE_NAME}"

                    tar \
                      --exclude=.git \
                      --exclude=.gitignore \
                      -czf "${FILE_NAME}" -C "${APP_DIR}" .

                    ls -lh "${FILE_NAME}"
                '''
            }
        }

        stage('Upload to Nexus (Maven2 Style)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${NEXUS_CRED_ID}",
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh '''
                        curl -v -u "${NEXUS_USER}:${NEXUS_PASS}" \
                          --upload-file "${FILE_NAME}" \
                          "${NEXUS_URL}/repository/${NEXUS_REPO}/${NEXUS_PATH}"
                    '''
                }
            }
        }

    
    }

    post {
        success {
            echo "Artifact uploaded successfully:"
            echo "${NEXUS_URL}/repository/${NEXUS_REPO}/${NEXUS_PATH}"
        }
        failure {
            echo "Build or upload failed."
        }
    }
}